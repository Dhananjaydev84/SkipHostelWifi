{
  "manifest_version": 3,
  "name": "SkipHostel-Wifi",
  "version": "1.1",
  "description": "Automates WiFi login for Rajagiri Men's Hostel (Sanjoe) to avoid repeated manual authentication.",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "idle"
  ],
  "host_permissions": [
    "http://192.168.0.66/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon.png",
      "48": "images/icon.png",
      "128": "images/icon.png"
    }
  },
  "icons": {
    "16": "images/icon.png",
    "48": "images/icon.png",
    "128": "images/icon.png"
  }
}
