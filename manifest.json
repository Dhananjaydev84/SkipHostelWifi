{
  "manifest_version": 3,
  "name": "SkipHostel-Wifi",
  "version": "1.1",
  "description": "Automates WiFi login for Rajagiri Men's Hostel (Sanjoe) to avoid repeated manual authentication.",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://192.168.0.66/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}